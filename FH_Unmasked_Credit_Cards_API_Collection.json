{
  "info": {
    "name": "FH Unmasked Credit Card API Collection",
    "description": "Complete collection for retrieving unmasked credit card account numbers from Bottomline DBIQ APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "inherit"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// OAuth Token Management",
          "if (!pm.collectionVariables.get('access_token') || ",
          "    Date.now() > pm.collectionVariables.get('token_expires_at')) {",
          "    console.log('Getting new access token...');",
          "    ",
          "    pm.sendRequest({",
          "        url: pm.variables.get('baseUrl') + '/oauth/v1/token',",
          "        method: 'POST',",
          "        header: {",
          "            'Content-Type': 'application/x-www-form-urlencoded'",
          "        },",
          "        auth: {",
          "            type: 'basic',",
          "            basic: [{",
          "                key: 'username',",
          "                value: pm.variables.get('client_id')",
          "            }, {",
          "                key: 'password',",
          "                value: pm.variables.get('client_secret')",
          "            }]",
          "        },",
          "        body: {",
          "            mode: 'urlencoded',",
          "            urlencoded: [{",
          "                key: 'grant_type',",
          "                value: pm.variables.get('grant_type')",
          "            }, {",
          "                key: 'scope',",
          "                value: pm.variables.get('scope')",
          "            }]",
          "        }",
          "    }, function (err, response) {",
          "        if (err) {",
          "            console.error('OAuth request failed:', err);",
          "            throw new Error('OAuth authentication failed');",
          "        }",
          "        ",
          "        const responseJson = response.json();",
          "        if (response.code === 200 && responseJson.access_token) {",
          "            const expiresIn = responseJson.expires_in || 3600;",
          "            const expiresAt = Date.now() + (expiresIn * 1000);",
          "            ",
          "            pm.collectionVariables.set('access_token', responseJson.access_token);",
          "            pm.collectionVariables.set('token_expires_at', expiresAt);",
          "            ",
          "            console.log('Access token obtained successfully');",
          "        } else {",
          "            console.error('OAuth failed:', responseJson);",
          "            throw new Error('OAuth authentication failed: ' + JSON.stringify(responseJson));",
          "        }",
          "    });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "token_expires_at",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get OAuth Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', 'Bearer ' + jsonData.access_token);",
                  "    console.log('Access token set successfully');",
                  "} else {",
                  "    console.log('Authentication failed:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{client_id}}"
                },
                {
                  "key": "password",
                  "value": "{{client_secret}}"
                }
              ]
            },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "{{grant_type}}"
                },
                {
                  "key": "scope",
                  "value": "{{scope}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/oauth/v1/token",
              "host": ["{{baseUrl}}"],
              "path": ["oauth", "v1", "token"]
            }
          }
        }
      ]
    },
    {
      "name": "Data Profiling",
      "item": [
        {
          "name": "Get All Usergroups",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "onboarding-usergroup-provisioning", "usergroups"]
            }
          }
        },
        {
        	"name": "Search User Groups",
        	"request": {
        		"method": "POST",
        		"header": [
        			{
        				"key": "Content-Type",
        				"value": "application/json"
        			},
        			{
        				"key": "HTTP_nameid",
        				"value": "{{sso_id}}"
        			},
        			{
        				"key": "Authorization",
        				"value": "{{access_token}}"
        			}
        		],
        		"body": {
        			"mode": "raw",
        			"raw": "{\n  \"filters\": [\n    {\n      \"searchField\": \"COMPANYNAME\",\n      \"searchText\": \"Demo\",\n      \"searchType\": \"CONTAINS\"\n    }\n  ],\n  \"pagination\": {\n    \"page\": 1,\n    \"limit\": 50\n  },\n  \"sortBy\": {\n    \"field\": \"COMPANYNAME\",\n    \"order\": \"ASC\"\n  }\n}"
        		},
        		"url": {
        			"raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups:search",
        			"host": [
        				"{{baseUrl}}"
        			],
        			"path": [
        				"digital-banking",
        				"onboarding-usergroup-provisioning",
        				"usergroups:search"
        			]
        		}
        	}
        },
        {
          "name": "Get User Group Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/:userGroupId",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "onboarding-usergroup-provisioning", "usergroups", ":userGroupId"],
              "variable": [
                {
                  "key": "userGroupId",
                  "value": "",
                  "description": "Enter the UserGroup ID to retrieve details"
                }
              ]
            },
            "description": "Get detailed information about a specific user group including basic info, product settings, entitlements, and limits. Use a userGroupId discovered from previous endpoints."
          }
        },
        {
          "name": "Get All Accounts for User Group",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/:userGroupId/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "onboarding-usergroup-provisioning", "usergroups", ":userGroupId", "accounts"],
              "variable": [
                {
                  "key": "userGroupId",
                  "value": "",
                  "description": "Enter the UserGroup ID to retrieve all accounts"
                }
              ]
            },
            "description": "Read all client accounts and their details for a User Group. This endpoint lists all accounts (checking, savings, credit cards, etc.) associated with a specific usergroup. Perfect for data profiling to discover what account types and numbers exist before testing masked vs unmasked access."
          }
        }
      ]
    },
    {
      "name": "Usergroup Account Access - Unmasked Credit Cards",
      "item": [
        {
          "name": "Search Credit Card Accounts (UNMASKED)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"criteria\": [\n    {\n      \"fieldName\": \"accountType\",\n      \"fieldValue\": [\"CC\"]\n    },\n    {\n      \"fieldName\": \"userGroupId\", \n      \"fieldValue\": [\"12345\"]\n    }\n  ],\n  \"unmaskColumns\": true,\n  \"operationalData\": true,\n  \"limit\": 25,\n  \"page\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/accounts:search",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "accounts:search"
              ]
            },
            "description": "Search for credit card accounts with UNMASKED account numbers. Uses the ListViewRequest schema with unmaskColumns=true to return complete, unmasked account numbers for credit card accounts (accountType=CC). Change the userGroupId value in the request body to target a specific user group discovered from the Data Profiling endpoints."
          },
          "response": []
        },
        {
          "name": "Search Credit Card Accounts (MASKED)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"criteria\": [\n    {\n      \"fieldName\": \"accountType\",\n      \"fieldValue\": [\"CC\"]\n    },\n    {\n      \"fieldName\": \"userGroupId\",\n      \"fieldValue\": [\"12345\"]\n    }\n  ],\n  \"unmaskColumns\": false,\n  \"operationalData\": true,\n  \"limit\": 25,\n  \"page\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/accounts:search",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "accounts:search"
              ]
            },
            "description": "Search for credit card accounts with MASKED account numbers for comparison. Uses the same ListViewRequest schema but with unmaskColumns=false to return masked account numbers (e.g., ****1234). Compare results with the UNMASKED version to demonstrate the masking functionality."
          },
          "response": []
        },
        {
          "name": "Search All Account Types (UNMASKED)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"criteria\": [\n    {\n      \"fieldName\": \"userGroupId\",\n      \"fieldValue\": [\"12345\"]\n    }\n  ],\n  \"unmaskColumns\": true,\n  \"operationalData\": true,\n  \"limit\": 25,\n  \"page\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/accounts:search",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "accounts:search"
              ]
            },
            "description": "Search for all account types (checking, savings, credit cards, etc.) with UNMASKED account numbers. No accountType filter is applied, so this returns all accounts for the specified user group with complete account numbers visible. Useful for comprehensive account discovery."
          },
          "response": []
        }
      ]
    }
  ]
}