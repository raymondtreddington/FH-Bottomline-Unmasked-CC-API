        				{
        					"key": "search_type",
        					"value": "CONTAINS",
        					"description": "Search type (CONTAINS, EXACT, STARTS_WITH)"
        				},
        				{
        					"key": "limit",
        					"value": "50",
        					"description": "Maximum number of results to return (default: 50)"
