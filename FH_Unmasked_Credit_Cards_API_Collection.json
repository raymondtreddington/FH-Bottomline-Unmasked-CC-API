            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filters\": {\n    \"userGroup\": \"{{userGroupId}}\",\n    \"accountType\": \"CREDIT_CARD\"\n  },\n  \"sorting\": {\n    \"field\": \"ACCOUNTNUMBER\",\n    \"order\": \"ASC\"\n  },\n  \"pagination\": {\n    \"limit\": 50,\n    \"offset\": 0\n  }\n}"
