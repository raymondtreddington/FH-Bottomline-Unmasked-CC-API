{
  "info": {
    "name": "First Horizon - Unmasked Credit Card Accounts API",
    "description": "API collection for accessing unmasked credit card account numbers from Bottomline DBIQ. Demonstrates API-level bypass of UI masking for security/PCI compliance workflows.\n\nWorkflow: OAuth Authentication \u2192 Discover UserGroups \u2192 List Accounts \u2192 Search with Masking Control\n\n**Environment Variables Required:**\n- baseUrl: API base URL\n- client_id: OAuth client ID  \n- client_secret: OAuth client secret\n- scope: digital-banking\n- grant_type: client_credentials\n- sso_id: SSO identifier for HTTP_nameid header\n\n**Key Features:**\n- OAuth 2.0 client credentials flow with automatic token refresh\n- UserGroup discovery and account enumeration\n- Masked vs Unmasked account number demonstration\n- Proper field validation (USERGROUP, ACCOUNTNAME, ACCOUNTNUMBER, BANKCODE)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "inherit"
  },

  "variable": [
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "userGroupId",
      "value": "CPTR1",
      "type": "string"
    },
    {
      "key": "searchTerm",
      "value": "CPTR",
      "type": "string"
    },
    {
      "key": "accountNumber",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get OAuth Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{client_id}}"
                },
                {
                  "key": "password",
                  "value": "{{client_secret}}"
                }
              ]
            },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "{{grant_type}}"
                },
                {
                  "key": "scope",
                  "value": "{{scope}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/oauth/v1/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oauth",
                "v1",
                "token"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const responseJson = pm.response.json();",
                  "    const accessToken = 'Bearer ' + responseJson.access_token;",
                  "    pm.collectionVariables.set('access_token', accessToken);",
                  "    console.log('Access token set:', accessToken.substring(0, 20) + '...');",
                  "} else {",
                  "    console.log('OAuth failed with status:', pm.response.code);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Data Profiling",
      "item": [
        {
          "name": "Get All UserGroups",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "usergroups"
              ]
            }
          }
        },
        {
          "name": "Search User Groups",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"listViewRequest\\\": {\\n    \\\"filters\\\": [\\n      {\\n        \\\"fieldName\\\": \\\"GROUPNAME\\\",\\n        \\\"searchText\\\": \\\"{{searchTerm}}\\\",\\n        \\\"type\\\": \\\"CONTAINS\\\"\\n      }\\n    ]\\n  }\\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups:search",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "usergroups:search"
              ]
            }
          }
        },
        {
          "name": "Get User Group Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/:userGroupId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "usergroups",
                ":userGroupId"
              ],
              "variable": [
                {
                  "key": "userGroupId",
                  "value": "12345",
                  "description": "Replace with actual UserGroup ID from previous calls"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Accounts for User Group",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/:userGroupId/accounts?includeUnmaskedAccount=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "usergroups",
                ":userGroupId",
                "accounts"
              ],
              "query": [
                {
                  "key": "includeUnmaskedAccount",
                  "value": "true",
                  "description": "Include unmasked account numbers in response"
                }
              ],
              "variable": [
                {
                  "key": "userGroupId",
                  "value": "CPTR1",
                  "description": "Default userGroupId for testing"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Account Search - CORRECTED",
      "item": [
        {
          "name": "Search Accounts - UNMASKED (Credit Cards)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{sso_id}}",
                "description": "For Sandbox environment"
              },
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}",
                "disabled": true,
                "description": "For Client environment - enable this and disable HTTP_UserIdentifier"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"unmaskColumns\\\": [\\\"ACCOUNT_NBR\\\"],\\n  \\\"listViewRequest\\\": {\\n    \\\"filters\\\": [\\n      {\\n        \\\"fieldName\\\": \\\"USERGROUP\\\",\\n        \\\"searchText\\\": \\\"{{userGroupId}}\\\",\\n        \\\"type\\\": \\\"EXACT\\\"\\n      }\\n    ]\\n  }\\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/accounts:search",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "accounts:search"
              ]
            }
          }
        },
