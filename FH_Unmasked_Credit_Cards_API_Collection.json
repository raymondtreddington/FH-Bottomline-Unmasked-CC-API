{
  "info": {
    "name": "First Horizon - Bottomline DBIQ Unmasked Credit Card APIs",
    "description": "Collection of Bottomline DBIQ API endpoints that can potentially retrieve unmasked credit card account numbers for First Horizon Bank",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://sandbox.bottomline.app"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "client_id",
      "value": "YOUR_CLIENT_ID"
    },
    {
      "key": "client_secret",
      "value": "YOUR_CLIENT_SECRET"
    },
    {
      "key": "ssoid",
      "value": "SBX:ADMIN"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get OAuth2 Access Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/oauth2/token",
              "host": ["{{baseUrl}}"],
              "path": ["oauth2", "token"]
            },
            "description": "Get OAuth2 bearer token for API authentication"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const responseJson = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', responseJson.access_token);",
                  "    console.log('Access token set:', responseJson.access_token);",
                  "} else {",
                  "    console.log('Failed to get access token:', pm.response.text());",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "HIGH PRIORITY - Credit Card Endpoints",
      "item": [
        {
          "name": "Get All Credit Card Account Summaries",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{ssoid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listViewConfig\": {\n    \"requestId\": \"cc_all_001\",\n    \"sortOrder\": \"ASC\",\n    \"sortField\": \"accountNumber\"\n  },\n  \"filters\": {\n    \"accountStatus\": \"ACTIVE\",\n    \"includeUnmaskedAccount\": true\n  },\n  \"pagination\": {\n    \"pageSize\": 50,\n    \"pageNumber\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-balances/balanceAndTransaction/creditCardAccounts/ALLACCOUNTS/accountSummary/getListView",
              "host": ["{{baseUrl}}"],
              "path": [
                "digital-banking",
                "reporting-account-balances",
                "balanceAndTransaction",
                "creditCardAccounts",
                "ALLACCOUNTS",
                "accountSummary",
                "getListView"
              ]
            },
            "description": "Retrieve all credit card account summaries - HIGHEST PRIORITY for unmasked account numbers"
          }
        },
        {
          "name": "Get Current Day Credit Card Summaries",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{ssoid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listViewConfig\": {\n    \"requestId\": \"cc_currday_001\",\n    \"sortOrder\": \"ASC\",\n    \"sortField\": \"accountNumber\"\n  },\n  \"filters\": {\n    \"accountStatus\": \"ACTIVE\",\n    \"includeUnmaskedAccount\": true,\n    \"balanceType\": \"CURRENT\"\n  },\n  \"pagination\": {\n    \"pageSize\": 50,\n    \"pageNumber\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-balances/balanceAndTransaction/creditCardAccounts/CURRDAY/accountSummary/getListView",
              "host": ["{{baseUrl}}"],
              "path": [
                "digital-banking",
                "reporting-account-balances",
                "balanceAndTransaction",
                "creditCardAccounts",
                "CURRDAY",
                "accountSummary",
                "getListView"
              ]
            },
            "description": "Get current day credit card account summaries with unmasked account numbers"
          }
        },
        {
          "name": "Request Real-Time Credit Card Balances",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{ssoid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accounts\": [\n    {\n      \"accountNumber\": \"4111111111111111\",\n      \"accountType\": \"CREDIT_CARD\"\n    }\n  ],\n  \"requestId\": \"rt_cc_bal_001\",\n  \"priority\": \"HIGH\",\n  \"timeoutSeconds\": 30,\n  \"includeUnmaskedAccount\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-balances/balanceAndTransaction/creditCardAccounts/accountSummary/requestRealTimeBalances",
              "host": ["{{baseUrl}}"],
              "path": [
                "digital-banking",
                "reporting-account-balances",
                "balanceAndTransaction",
                "creditCardAccounts",
                "accountSummary",
                "requestRealTimeBalances"
              ]
            },
            "description": "Request real-time credit card balances - may return unmasked account numbers"
          }
        },
        {
          "name": "Get Credit Card Transaction List",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{ssoid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listViewConfig\": {\n    \"requestId\": \"cc_txn_001\",\n    \"sortOrder\": \"DESC\",\n    \"sortField\": \"transactionDate\"\n  },\n  \"filters\": {\n    \"dateRange\": {\n      \"startDate\": \"2024-01-01\",\n      \"endDate\": \"2024-12-31\"\n    },\n    \"includeUnmaskedAccount\": true,\n    \"transactionCategory\": \"ALL\"\n  },\n  \"pagination\": {\n    \"pageSize\": 50,\n    \"pageNumber\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-transactions/balanceAndTransaction/creditCardAccounts/currentDay/getTransactions/getListView",
              "host": ["{{baseUrl}}"],
              "path": [
                "digital-banking",
                "reporting-account-transactions",
                "balanceAndTransaction",
                "creditCardAccounts",
                "currentDay",
                "getTransactions",
                "getListView"
              ]
            },
            "description": "Get credit card transaction list - may expose unmasked account numbers in transaction details"
          }
        },
        {
          "name": "Request Real-Time Credit Card Transactions",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{ssoid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accounts\": [\n    {\n      \"accountNumber\": \"4111111111111111\",\n      \"accountType\": \"CREDIT_CARD\"\n    }\n  ],\n  \"requestId\": \"rt_cc_txn_001\",\n  \"priority\": \"HIGH\",\n  \"timeoutSeconds\": 30,\n  \"includeUnmaskedAccount\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-transactions/balanceAndTransaction/creditCardAccounts/getTransactions/requestRealTimeTransactions",
              "host": ["{{baseUrl}}"],
              "path": [
                "digital-banking",
                "reporting-account-transactions",
                "balanceAndTransaction",
                "creditCardAccounts",
                "getTransactions",
                "requestRealTimeTransactions"
              ]
            },
            "description": "Request real-time credit card transactions - may return unmasked account numbers"
          }
        }
      ]
    },
    {
      "name": "MEDIUM PRIORITY - Account Management",
      "item": [
        {
          "name": "Get All Client Accounts for User Group",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{ssoid}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/{{userGroupId}}/accounts?limit=50&page=1",
              "host": ["{{baseUrl}}"],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "usergroups",
                "{{userGroupId}}",
                "accounts"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            },
            "description": "Get all client accounts for a user group - provisioning APIs often expose full account details"
          }
        },
        {
          "name": "Search Accounts by Criteria",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{ssoid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"searchCriteria\": {\n    \"accountType\": \"CREDIT_CARD\",\n    \"accountStatus\": \"ACTIVE\",\n    \"includeUnmaskedAccount\": true\n  },\n  \"sortBy\": \"ACCOUNTNUMBER\",\n  \"sortOrder\": \"ASC\",\n  \"pagination\": {\n    \"pageSize\": 50,\n    \"pageNumber\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/accounts:search",
              "host": ["{{baseUrl}}"],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "accounts:search"
              ]
            },
            "description": "Search accounts by criteria - supports ACCOUNTNUMBER field and may return unmasked data"
          }
        },
        {
          "name": "Search User Groups",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{ssoid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"searchCriteria\": {\n    \"status\": \"AP\",\n    \"marketSegment\": \"COMMERCIAL\",\n    \"includeAccountDetails\": true\n  },\n  \"pagination\": {\n    \"pageSize\": 25,\n    \"pageNumber\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups:search",
              "host": ["{{baseUrl}}"],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "usergroups:search"
              ]
            },
            "description": "Search user groups - may include associated account details with full account numbers"
          }
        },
        {
          "name": "Get User Group Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{ssoid}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/{{userGroupId}}",
              "host": ["{{baseUrl}}"],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "usergroups",
                "{{userGroupId}}"
              ]
            },
            "description": "Get user group details including account information - may expose full account numbers"
          }
        },
        {
          "name": "Create Client Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{ssoid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountNumber\": \"4111111111111111\",\n  \"accountName\": \"Test Credit Card Account\",\n  \"accountType\": \"CREDIT_CARD\",\n  \"currency\": \"USD\",\n  \"status\": \"ACTIVE\",\n  \"bankCode\": \"021000021\",\n  \"includeUnmaskedAccount\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/{{userGroupId}}/accounts",
              "host": ["{{baseUrl}}"],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "usergroups",
                "{{userGroupId}}",
                "accounts"
              ]
            },
            "description": "Create client account - response may include full unmasked account details"
          }
        },
        {
          "name": "Update Client Account",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{ssoid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountName\": \"Updated Credit Card Account\",\n  \"status\": \"ACTIVE\",\n  \"includeUnmaskedAccount\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/{{userGroupId}}/accounts",
              "host": ["{{baseUrl}}"],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "usergroups",
                "{{userGroupId}}",
                "accounts"
              ]
            },
            "description": "Update client account - response may expose unmasked account number"
          }
        },
        {
          "name": "Retrieve Account Limits",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "HTTP_UserIdentifier",
                "value": "{{ssoid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filters\": {\n    \"accountType\": \"CREDIT_CARD\",\n    \"limitType\": \"ALL\",\n    \"includeAccountDetails\": true\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/{{userGroupId}}/accountlimits:retrieve",
              "host": ["{{baseUrl}}"],
              "path": [
                "digital-banking",
                "onboarding-usergroup-provisioning",
                "usergroups",
                "{{userGroupId}}",
                "accountlimits:retrieve"
              ]
            },
            "description": "Retrieve account limits - may include full account details with unmasked numbers"
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-set timestamp for request IDs",
          "const timestamp = Date.now();",
          "pm.globals.set('timestamp', timestamp);"
        ]
      }
    }
  ]
}