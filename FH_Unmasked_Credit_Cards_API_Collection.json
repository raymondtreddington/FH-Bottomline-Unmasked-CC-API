            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"unmaskColumns\\\": [\\\"ACCOUNT_NBR\\\"],\\n  \\\"listViewRequest\\\": {\\n    \\\"filters\\\": [\\n      {\\n        \\\"fieldName\\\": \\\"USERGROUP\\\",\\n        \\\"searchText\\\": \\\"CPTR1\\\",\\n        \\\"type\\\": \\\"EXACT\\\"\\n      }\\n    ]\\n  }\\n}",
              "options": {
