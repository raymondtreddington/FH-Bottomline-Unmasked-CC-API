{
	"info": {
		"_postman_id": "12345678-1234-1234-1234-123456789012",
		"name": "FH Bottomline Unmasked Credit Card APIs",
		"description": "Postman collection demonstrating how to access unmasked credit card account numbers from Bottomline's DBIQ API for First Horizon Bank. This collection shows the difference between masked (****1234) and unmasked (full 16-digit) account numbers.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Get OAuth Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    pm.collectionVariables.set('access_token', 'Bearer ' + responseJson.access_token);",
									"    console.log('Access token obtained successfully');",
									"} else {",
									"    console.log('Authentication failed with status:', pm.response.code);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "basic",
							"basic": [
								{
									"key": "username",
									"value": "{{client_id}}",
									"type": "string"
								},
								{
									"key": "password",
									"value": "{{client_secret}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "grant_type",
									"value": "{{grant_type}}",
									"type": "text"
								},
								{
									"key": "scope",
									"value": "{{scope}}",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/oauth/v1/token",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"oauth",
								"v1",
								"token"
							]
						},
						"description": "Obtain OAuth access token using client credentials flow. Uses Basic Auth with client_id/client_secret and expects grant_type=client_credentials, scope=dbiq_all."
					},
					"response": []
				}
			]
		},
		{
			"name": "Data Profiling",
			"item": [
				{
					"name": "Get All User Groups",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{access_token}}",
								"type": "text"
							},
							{
								"key": "HTTP_nameid",
								"value": "{{sso_id}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"digital-banking",
								"onboarding-usergroup-provisioning",
								"usergroups"
							]
						},
						"description": "Retrieve all user groups in the system. This helps identify which groups have access to credit card accounts."
					},
					"response": []
				},
				{
					"name": "Get User Group Details",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{access_token}}",
								"type": "text"
							},
							{
								"key": "HTTP_nameid",
								"value": "{{sso_id}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/{{userGroupId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"digital-banking",
								"onboarding-usergroup-provisioning",
								"usergroups",
								"{{userGroupId}}"
							]
						},
						"description": "Get detailed information about a specific user group, including permissions and account access rules."
					},
					"response": []
				},
				{
					"name": "Get User Group Accounts",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{access_token}}",
								"type": "text"
							},
							{
								"key": "HTTP_nameid",
								"value": "{{sso_id}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/{{userGroupId}}/accounts",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"digital-banking",
								"onboarding-usergroup-provisioning",
								"usergroups",
								"{{userGroupId}}",
								"accounts"
							]
						},
						"description": "List all accounts associated with a user group. Look for credit card accounts in the response to identify which accounts support unmasked number retrieval."
					},
					"response": []
				},
				{
					"name": "Get User Group Limits",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{access_token}}",
								"type": "text"
							},
							{
								"key": "HTTP_nameid",
								"value": "{{sso_id}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/{{userGroupId}}/limits",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"digital-banking",
								"onboarding-usergroup-provisioning",
								"usergroups",
								"{{userGroupId}}",
								"limits"
							]
						},
						"description": "Get transaction limits (daily, per-transaction) configured for the user group. Important for understanding access levels and permissions."
					},
					"response": []
				}
			]
		},
		{
			"name": "Helpful Endpoints",
			"item": [
				{
					"name": "Credit Card Balance (Current Day) - Masked",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "{{access_token}}",
								"type": "text"
							},
							{
								"key": "HTTP_nameid",
								"value": "{{sso_id}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"filters\": {\n    \"includeUnmaskedAccount\": false\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/digital-banking/reporting-account-balances/balanceAndTransaction/creditCardAccounts/CURRDAY/accountSummary/getListView",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"digital-banking",
								"reporting-account-balances",
								"balanceAndTransaction",
								"creditCardAccounts",
								"CURRDAY",
								"accountSummary",
								"getListView"
							]
						},
						"description": "Get current day credit card account balances with MASKED account numbers (shows ****1234). Compare response with unmasked version to see the difference."
					},
					"response": []
				},
				{
					"name": "Credit Card Balance (Current Day) - Unmasked",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "{{access_token}}",
								"type": "text"
							},
							{
								"key": "HTTP_nameid",
								"value": "{{sso_id}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"filters\": {\n    \"includeUnmaskedAccount\": true\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/digital-banking/reporting-account-balances/balanceAndTransaction/creditCardAccounts/CURRDAY/accountSummary/getListView",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"digital-banking",
								"reporting-account-balances",
								"balanceAndTransaction",
								"creditCardAccounts",
								"CURRDAY",
								"accountSummary",
								"getListView"
							]
						},
						"description": "Get current day credit card account balances with UNMASKED account numbers (full 16 digits). Set includeUnmaskedAccount=true in filters. This is the key endpoint that provides full credit card numbers."
					},
					"response": []
				},
				{
					"name": "Credit Card Transactions - Masked",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "{{access_token}}",
								"type": "text"
							},
							{
								"key": "HTTP_nameid",
								"value": "{{sso_id}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"filters\": {\n    \"includeUnmaskedAccount\": false,\n    \"accountNumber\": \"{{creditCardAccountNumber}}\"\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/digital-banking/reporting-account-transactions/balanceAndTransaction/creditCardAccounts/transaction/getListView",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"digital-banking",
								"reporting-account-transactions",
								"balanceAndTransaction",
								"creditCardAccounts",
								"transaction",
								"getListView"
							]
						},
						"description": "Get credit card transaction history with MASKED account numbers (shows ****1234). Set creditCardAccountNumber variable first."
					},
					"response": []
				},
				{
					"name": "Credit Card Transactions - Unmasked",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "{{access_token}}",
								"type": "text"
							},
							{
								"key": "HTTP_nameid",
								"value": "{{sso_id}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"filters\": {\n    \"includeUnmaskedAccount\": true,\n    \"accountNumber\": \"{{creditCardAccountNumber}}\"\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/digital-banking/reporting-account-transactions/balanceAndTransaction/creditCardAccounts/transaction/getListView",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"digital-banking",
								"reporting-account-transactions",
								"balanceAndTransaction",
								"creditCardAccounts",
								"transaction",
								"getListView"
							]
						},
						"description": "Get credit card transaction history with UNMASKED account numbers (full 16 digits). Set includeUnmaskedAccount=true in filters. Compare response with masked version."
					},
					"response": []
				}
			]
		}
