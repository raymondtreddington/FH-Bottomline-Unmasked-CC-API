{
  "info": {
    "name": "First Horizon - Bottomline DBIQ Credit Card Data Profiling",
    "description": "Collection for discovering usergroups and retrieving credit card account details (masked/unmasked) from Bottomline DBIQ. Workflow: 1) Data Profiling - Find valid usergroups and identify those with credit card accounts, 2) Helpful Endpoints - Retrieve account details with masking flags to control masked vs unmasked display.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.1"
  },
  "auth": {
    "type": "inherit"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get OAuth2 Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('access_token', jsonData.access_token);",
                  "    console.log('Access token updated:', jsonData.access_token);",
                  "} else {", 
                  "    console.log('Token request failed:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{client_id}}",
                  "type": "string"
                },
                {
                  "key": "password", 
                  "value": "{{client_secret}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "{{grant_type}}"
                },
                {
                  "key": "scope",
                  "value": "{{scope}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/oauth/v1/token",
              "host": ["{{baseUrl}}"],
              "path": ["oauth", "v1", "token"]
            },
            "description": "Obtain OAuth2 access token using client credentials flow with Basic Auth"
          }
        }
      ]
    },
    {
      "name": "Data Profiling",
      "description": "Endpoints to discover and profile the sandbox environment - find valid usergroups and identify those with credit card accounts",
      "item": [
        {
          "name": "List All Usergroups",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization", 
                "value": "{{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "onboarding-usergroup-provisioning", "usergroups"]
            },
            "description": "Retrieve all usergroups to identify valid usergroup IDs for further queries"
          }
        },
        {
          "name": "Get Usergroup Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}" 
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/:userGroupId",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "onboarding-usergroup-provisioning", "usergroups", ":userGroupId"],
              "variable": [
                {
                  "key": "userGroupId",
                  "value": "",
                  "description": "The usergroup ID obtained from 'List All Usergroups'"
                }
              ]
            },
            "description": "Get detailed information about a specific usergroup. Replace {userGroupId} with actual ID from usergroups list."
          }
        },
        {
          "name": "List Accounts for Usergroup",
          "request": {
            "method": "GET", 
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/:userGroupId/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "onboarding-usergroup-provisioning", "usergroups", ":userGroupId", "accounts"],
              "variable": [
                {
                  "key": "userGroupId",
                  "value": "",
                  "description": "The usergroup ID obtained from 'List All Usergroups'"
                }
              ]
            },
            "description": "List all accounts associated with a usergroup to identify credit card accounts. Look for accountType = 'CREDIT_CARD' or similar."
          }
        },
        {
          "name": "Search Credit Card Accounts",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid", 
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountType\": \"CREDIT_CARD\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-balances/credit-card/search",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "reporting-account-balances", "credit-card", "search"]
            },
            "description": "Search specifically for credit card accounts across all accessible usergroups"
          }
        }
      ]
    },
    {
      "name": "Helpful Endpoints", 
      "description": "Core endpoints for retrieving credit card account details with masking control - compare masked vs unmasked responses",
      "item": [
        {
          "name": "Credit Card Balance (Current Day) - Masked",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization", 
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userGroupId\": \"{{userGroupId}}\",\n  \"includeUnmaskedAccount\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-balances/credit-card/current-day", 
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "reporting-account-balances", "credit-card", "current-day"]
            },
            "description": "Get credit card balances with MASKED account numbers (****1234 format). Set includeUnmaskedAccount=false."
          }
        },
        {
          "name": "Credit Card Balance (Current Day) - Unmasked",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type", 
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userGroupId\": \"{{userGroupId}}\",\n  \"includeUnmaskedAccount\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-balances/credit-card/current-day",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "reporting-account-balances", "credit-card", "current-day"]
            },
            "description": "Get credit card balances with UNMASKED account numbers (full 16 digits). Set includeUnmaskedAccount=true. Compare response with masked version."
          }
        },
        {
          "name": "Credit Card Transactions - Masked",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw", 
              "raw": "{\n  \"userGroupId\": \"{{userGroupId}}\",\n  \"accountNumber\": \"{{creditCardAccountNumber}}\",\n  \"includeUnmaskedAccount\": false,\n  \"startDate\": \"2024-01-01\",\n  \"endDate\": \"2024-12-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-transactions/credit-card/transaction-history",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "reporting-account-transactions", "credit-card", "transaction-history"]
            },
            "description": "Get credit card transaction history with MASKED account numbers. Set includeUnmaskedAccount=false."
          }
        },
        {
          "name": "Credit Card Transactions - Unmasked",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userGroupId\": \"{{userGroupId}}\",\n  \"accountNumber\": \"{{creditCardAccountNumber}}\",\n  \"includeUnmaskedAccount\": true,\n  \"startDate\": \"2024-01-01\",\n  \"endDate\": \"2024-12-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-transactions/credit-card/transaction-history",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "reporting-account-transactions", "credit-card", "transaction-history"]
            },
            "description": "Get credit card transaction history with UNMASKED account numbers. Set includeUnmaskedAccount=true. Compare response with masked version."
          }
        },
        {
          "name": "Get Account Details (Provisioning)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization", 
                "value": "{{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/:userGroupId/accounts/:accountNumber",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "onboarding-usergroup-provisioning", "usergroups", ":userGroupId", "accounts", ":accountNumber"],
              "variable": [
                {
                  "key": "userGroupId",
                  "value": "",
                  "description": "The usergroup ID"
                },
                {
                  "key": "accountNumber",
                  "value": "",
                  "description": "The account number"
                }
              ]
            },
            "description": "Get detailed account information via provisioning endpoint - typically returns unmasked data for admin operations. Replace {userGroupId} and {accountNumber} with actual values."
          }
        },
        {
          "name": "Account Balance Summary (All Types)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userGroupId\": \"{{userGroupId}}\",\n  \"includeUnmaskedAccount\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-balances/summary",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "reporting-account-balances", "summary"]
            },
            "description": "Get balance summary for all account types including credit cards. Use includeUnmaskedAccount flag to control masking."
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Check if access token exists",
          "if (!pm.environment.get('access_token')) {",
          "    console.log('No access token found - run Authentication > Get OAuth2 Access Token first');",
          "}"
        ]
      }
    }
  ]
}