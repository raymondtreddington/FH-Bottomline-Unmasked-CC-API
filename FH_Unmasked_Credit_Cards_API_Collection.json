{
  "info": {
    "name": "FH Bottomline Unmasked Credit Card APIs",
    "description": "Postman collection demonstrating how to access unmasked credit card account numbers from Bottomline's DBIQ API for First Horizon Bank. This collection shows the difference between masked (****1234) and unmasked (full 16-digit) account numbers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// This collection inherits environment variables from the parent environment",
          "// Required variables: baseUrl, client_id, client_secret, scope, grant_type, sso_id"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "access_token",
      "value": "",
      "description": "OAuth access token - will be set by authentication request"
    },
    {
      "key": "userGroupId", 
      "value": "",
      "description": "User Group ID discovered from Data Profiling endpoints"
    },
    {
      "key": "creditCardAccountNumber",
      "value": "",
      "description": "Credit card account number for transaction queries"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get OAuth Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', 'Bearer ' + jsonData.access_token);",
                  "    console.log('Access token set successfully');",
                  "} else {",
                  "    console.log('Authentication failed:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{client_id}}"
                },
                {
                  "key": "password", 
                  "value": "{{client_secret}}"
                }
              ]
            },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "{{grant_type}}"
                },
                {
                  "key": "scope",
                  "value": "{{scope}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/oauth/v1/token",
              "host": ["{{baseUrl}}"],
              "path": ["oauth", "v1", "token"]
            },
            "description": "Authenticate using OAuth 2.0 Client Credentials flow. Uses Basic Auth with client_id/client_secret and returns access_token for subsequent API calls."
          }
        }
      ]
    },
    {
      "name": "Data Profiling",
      "item": [
        {
          "name": "Get User Groups",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listViewConfig\": {\n    \"requestId\": \"ug_list_001\",\n    \"sortOrder\": \"ASC\",\n    \"sortField\": \"userGroupName\"\n  },\n  \"pagination\": {\n    \"pageSize\": 50,\n    \"pageNumber\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "onboarding-usergroup-provisioning", "usergroups"]
            },
            "description": "Discover available user groups in the system. Use the userGroupId from this response in subsequent account queries."
          }
        },
        {
          "name": "Search User Groups",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filters\": {\n    \"companyName\": \"\",\n    \"status\": \"AP\",\n    \"marketSegment\": \"\"\n  },\n  \"pagination\": {\n    \"pageSize\": 50,\n    \"pageNumber\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups:search",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "onboarding-usergroup-provisioning", "usergroups:search"]
            },
            "description": "Search for user groups using filters like company name, status (AP=Approved), and market segment. Provides more detailed search capabilities than the basic list."
          }
        },
        {
          "name": "Get User Group Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/{{userGroupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "onboarding-usergroup-provisioning", "usergroups", "{{userGroupId}}"]
            },
            "description": "Get detailed information about a specific user group including basic info, product settings, entitlements, and limits. Use a userGroupId discovered from previous endpoints."
          }
        },
        {
          "name": "Get User Group Entitlements",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/{{userGroupId}}/entitlements",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "onboarding-usergroup-provisioning", "usergroups", "{{userGroupId}}", "entitlements"]
            },
            "description": "Get product entitlements for a user group that define which features and services the group can access. Essential for understanding what data they can view."
          }
        },
        {
          "name": "Get User Group Limits",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/digital-banking/onboarding-usergroup-provisioning/usergroups/{{userGroupId}}/limits",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "onboarding-usergroup-provisioning", "usergroups", "{{userGroupId}}", "limits"]
            },
            "description": "Get transaction limits (daily, per-transaction) configured for the user group. Important for understanding access levels and permissions."
          }
        },
        {
          "name": "Get All Credit Card Accounts",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid", 
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listViewConfig\": {\n    \"requestId\": \"cc_all_001\",\n    \"sortOrder\": \"ASC\",\n    \"sortField\": \"accountNumber\"\n  },\n  \"filters\": {\n    \"accountStatus\": \"ACTIVE\"\n  },\n  \"pagination\": {\n    \"pageSize\": 50,\n    \"pageNumber\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-balances/balanceAndTransaction/creditCardAccounts/ALLACCOUNTS/accountSummary/getListView",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "reporting-account-balances", "balanceAndTransaction", "creditCardAccounts", "ALLACCOUNTS", "accountSummary", "getListView"]
            },
            "description": "Get all credit card accounts across all usergroups that the authenticated user has access to. This is a system-wide search for credit card accounts."
          }
        }
      ]
    },
    {
      "name": "Helpful Endpoints", 
      "item": [
        {
          "name": "Credit Card Balance (Current Day) - Masked",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization", 
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listViewConfig\": {\n    \"requestId\": \"cc_bal_masked_001\",\n    \"sortOrder\": \"ASC\",\n    \"sortField\": \"accountNumber\"\n  },\n  \"filters\": {\n    \"accountStatus\": \"ACTIVE\",\n    \"includeUnmaskedAccount\": false\n  },\n  \"pagination\": {\n    \"pageSize\": 25,\n    \"pageNumber\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-balances/balanceAndTransaction/creditCardAccounts/CURRDAY/accountSummary/getListView",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "reporting-account-balances", "balanceAndTransaction", "creditCardAccounts", "CURRDAY", "accountSummary", "getListView"]
            },
            "description": "Get current day credit card balances with MASKED account numbers (****1234 format). Set includeUnmaskedAccount=false in the filters."
          }
        },
        {
          "name": "Credit Card Balance (Current Day) - Unmasked",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type", 
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listViewConfig\": {\n    \"requestId\": \"cc_bal_unmasked_001\",\n    \"sortOrder\": \"ASC\",\n    \"sortField\": \"accountNumber\"\n  },\n  \"filters\": {\n    \"accountStatus\": \"ACTIVE\",\n    \"includeUnmaskedAccount\": true\n  },\n  \"pagination\": {\n    \"pageSize\": 25,\n    \"pageNumber\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-balances/balanceAndTransaction/creditCardAccounts/CURRDAY/accountSummary/getListView",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "reporting-account-balances", "balanceAndTransaction", "creditCardAccounts", "CURRDAY", "accountSummary", "getListView"]
            },
            "description": "Get current day credit card balances with UNMASKED account numbers (full 16 digits). Set includeUnmaskedAccount=true in the filters. Compare response with masked version."
          }
        },
        {
          "name": "Credit Card Transactions - Masked",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw", 
              "raw": "{\n  \"listViewConfig\": {\n    \"requestId\": \"cc_txn_masked_001\",\n    \"sortOrder\": \"DESC\",\n    \"sortField\": \"transactionDate\"\n  },\n  \"filters\": {\n    \"dateRange\": {\n      \"startDate\": \"2024-01-01\",\n      \"endDate\": \"2024-12-31\"\n    },\n    \"accountNumber\": \"{{creditCardAccountNumber}}\",\n    \"includeUnmaskedAccount\": false\n  },\n  \"pagination\": {\n    \"pageSize\": 50,\n    \"pageNumber\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-transactions/balanceAndTransaction/creditCardAccounts/currentDay/getTransactions/getListView",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "reporting-account-transactions", "balanceAndTransaction", "creditCardAccounts", "currentDay", "getTransactions", "getListView"]
            },
            "description": "Get credit card transaction history with MASKED account numbers. Set includeUnmaskedAccount=false in filters."
          }
        },
        {
          "name": "Credit Card Transactions - Unmasked",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "HTTP_nameid",
                "value": "{{sso_id}}"
              },
              {
                "key": "Authorization",
                "value": "{{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw", 
              "raw": "{\n  \"listViewConfig\": {\n    \"requestId\": \"cc_txn_unmasked_001\",\n    \"sortOrder\": \"DESC\",\n    \"sortField\": \"transactionDate\"\n  },\n  \"filters\": {\n    \"dateRange\": {\n      \"startDate\": \"2024-01-01\",\n      \"endDate\": \"2024-12-31\"\n    },\n    \"accountNumber\": \"{{creditCardAccountNumber}}\",\n    \"includeUnmaskedAccount\": true\n  },\n  \"pagination\": {\n    \"pageSize\": 50,\n    \"pageNumber\": 1\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/digital-banking/reporting-account-transactions/balanceAndTransaction/creditCardAccounts/currentDay/getTransactions/getListView",
              "host": ["{{baseUrl}}"],
              "path": ["digital-banking", "reporting-account-transactions", "balanceAndTransaction", "creditCardAccounts", "currentDay", "getTransactions", "getListView"]
            },
            "description": "Get credit card transaction history with UNMASKED account numbers (full 16 digits). Set includeUnmaskedAccount=true in filters. Compare response with masked version."
          }
        }
      ]
    }
  ]
}